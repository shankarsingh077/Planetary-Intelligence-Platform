# Staging runtime template (no secrets)
# Do not commit real values.

# Runtime profile selectors
STREAM_PROFILE=redpanda
STORE_PROFILE=cloud

# Stream connectivity
PIP_STREAM_BOOTSTRAP_SERVERS=
PIP_STREAM_SECURITY_PROTOCOL=
PIP_STREAM_SASL_MECHANISM=
PIP_STREAM_USERNAME=
PIP_STREAM_PASSWORD=
PIP_STREAM_TOPIC_RAW=pip.raw.events
PIP_STREAM_TOPIC_ENRICHED=pip.enriched.events
PIP_STREAM_TOPIC_DLQ=pip.dlq.events

# Object store
PIP_CLOUD_OBJECT_BUCKET=
TRIAGE_EVENTS_GCS_URI=
PIP_CLOUD_OBJECT_PREFIX_RAW=raw/
PIP_CLOUD_OBJECT_PREFIX_EVENTS=events/
PIP_CLOUD_OBJECT_PREFIX_ENRICHED=events_enriched/
PIP_CLOUD_OBJECT_PREFIX_DLQ=dlq/

# Serving store
PIP_SQL_ENGINE=postgres
PIP_SQL_HOST=
PIP_SQL_PORT=5432
PIP_SQL_DATABASE=
PIP_SQL_USER=
PIP_SQL_PASSWORD=
PIP_SQL_SSLMODE=require

# Health and telemetry
PIP_HEALTHCHECK_TIMEOUT_SECONDS=5
PIP_METRICS_EXPORT_INTERVAL_SECONDS=30
PIP_TELEMETRY_ENV=staging

# Auth mode
TRIAGE_AUTH_MODE=header
TRIAGE_AUTH_TOKENS_JSON={}

# Audit persistence
TRIAGE_AUDIT_GCS_URI=
TRIAGE_REDIS_URL=
TRIAGE_REDIS_CACHE_TTL_SECONDS=30
TRIAGE_REDIS_TIMEOUT_SECONDS=0.25

# Live connector wave endpoint overrides (optional)
GDELT_API_ENDPOINT=
GDELT_QUERY=conflict OR sanctions OR military
GDELT_MAX_RECORDS=12
WEATHER_GOV_API_ENDPOINT=https://api.weather.gov/alerts/active
FRED_API_ENDPOINT=https://fred.stlouisfed.org/graph/fredgraph.csv?id=DGS10
COINGECKO_API_ENDPOINT=https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum,solana&vs_currencies=usd&include_24hr_change=true
ACLED_API_ENDPOINT=https://api.acleddata.com/acled/read
ACLED_EMAIL=
ACLED_ACCESS_KEY=
ACLED_ACCESS_TOKEN=
ACLED_LIMIT=20
EIA_API_ENDPOINT=https://api.eia.gov/v2/petroleum/pri/gnd/data/?frequency=daily&data[0]=value&sort[0][column]=period&sort[0][direction]=desc&offset=0&length=5
EIA_API_KEY=
AVIATIONSTACK_API_ENDPOINT=https://api.aviationstack.com/v1/flights
AVIATIONSTACK_API_KEY=
AVIATIONSTACK_API=
AVIATIONSTACK_LIMIT=20
ABUSEIPDB_API_ENDPOINT=https://api.abuseipdb.com/api/v2/blacklist
ABUSEIPDB_API_KEY=
ABUSEIPDB_CONFIDENCE_MIN=90
ABUSEIPDB_LIMIT=20
FINNHUB_API_KEY=
FINNHUB_SYMBOLS=SPY,QQQ,GC=F,CL=F
FINNHUB_QUOTE_ENDPOINT=https://finnhub.io/api/v1/quote
CORRIDORRISK_EVENTS_ENDPOINT=https://corridorrisk.io/api/events/red-sea
CORRIDORRISK_SCORE_ENDPOINT=https://corridorrisk.io/api/score/red-sea
CORRIDORRISK_WEATHER_ENDPOINT=https://corridorrisk.io/api/weather/red-sea
FRED_API_KEY=
FRED_SERIES_ID=DGS10
FRED_API_ENDPOINT=https://api.stlouisfed.org/fred/series/observations
ACLED_PASSWORD=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
AISSTREAM_API_KEY=
ICAO_API_KEY=
UCDP_ACCESS_TOKEN=
NASA_FIRMS_API_KEY=
GROK_API_KEY=

# Gemini AI — Used for AI Insights, Forecasts, and Briefs
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-04-17
