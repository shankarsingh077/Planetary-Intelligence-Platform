{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://planetary-intelligence/schemas/canonical/entity.schema.json",
  "title": "Entity",
  "type": "object",
  "required": ["entity_id", "type", "primary_name", "aliases", "identity_confidence", "updated_at"],
  "properties": {
    "entity_id": { "type": "string" },
    "type": { "type": "string" },
    "primary_name": { "type": "string" },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "language"],
        "properties": {
          "name": { "type": "string" },
          "language": { "type": "string" }
        }
      }
    },
    "organization_hierarchy": {
      "type": "object",
      "properties": {
        "parent_entity_id": { "type": ["string", "null"] },
        "subsidiary_entity_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "identity_confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
